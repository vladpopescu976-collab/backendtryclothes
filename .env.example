APP_ENV=development
DEBUG=true
PROJECT_NAME=TryClothes Backend
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=10080
APP_PUBLIC_BASE_URL=http://127.0.0.1:8000
DATABASE_URL=postgresql+psycopg://postgres.lpqbybdzlwbxbixxeqch:SUPABASE_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
REDIS_URL=redis://127.0.0.1:6379/0
EMAIL_DELIVERY_MODE=console
EMAIL_FROM=no-reply@tryclothes.app
EMAIL_FROM_NAME=TryClothes
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
ALLOWED_CORS_ORIGINS=["*"]
AUTO_CREATE_TABLES=true
AUTO_SEED_REFERENCE_DATA=true
TRYON_PROVIDER=fashn_api
TRYON_TIMEOUT_SECONDS=180
TRYON_POLL_INTERVAL_SECONDS=2
TRYON_NUM_INFERENCE_STEPS=22
TRYON_GUIDANCE_SCALE=2.5
TRYON_SEED=42
TRYON_RESULT_FORMAT=jpeg
TRYON_RESULT_JPEG_QUALITY=92
MAX_UPLOAD_SIZE_MB=15
FASHN_API_KEY=replace-with-your-fashn-api-key
FASHN_BASE_URL=https://api.fashn.ai/v1
FASHN_MODEL_NAME=tryon-v1.6
FASHN_GARMENT_PHOTO_TYPE=flat-lay
FASHN_OUTPUT_FORMAT=jpeg
FASHN_SEGMENTATION_FREE=true
FASHN_MODERATION_LEVEL=permissive
FASHN_RETURN_BASE64=false
OPENAI_API_KEY=
EXTERNAL_TRYON_API_URL=https://example.com/virtual-tryon
MODEL_COMMAND_TEMPLATE=
MODEL_COMMAND_WORKDIR=

CATVTON_PROJECT_DIR=
CATVTON_BASE_MODEL_PATH=booksforcharlie/stable-diffusion-inpainting
CATVTON_RESUME_PATH=zhengchong/CatVTON
CATVTON_DEVICE=cuda
CATVTON_MIXED_PRECISION=bf16
CATVTON_ALLOW_TF32=true
CATVTON_WIDTH=768
CATVTON_HEIGHT=1024
CATVTON_BLUR_FACTOR=9
CATVTON_REPAINT=true
CATVTON_PRELOAD_ON_STARTUP=true
CATVTON_MASK_CACHE_SIZE=16
CATVTON_FAIL_FAST=false
CATVTON_PRESERVE_ORIGINAL_RESOLUTION=false

# Production tip:
# for real signups use Resend or SMTP:
# EMAIL_DELIVERY_MODE=resend
# EMAIL_FROM=TryClothes <noreply@yourdomain.com>
# RESEND_API_KEY=your_resend_api_key
# For local CatVTON later:
# TRYON_PROVIDER=catvton
# CATVTON_PROJECT_DIR=/absolute/path/to/CatVTON
